# CoopSystem - Environment Variables Example
# Copie este arquivo para .env e ajuste os valores

# Database Configuration
DB_CONNECTION=Server=db;Database=CoopSystemNovo;User Id=sa;Password=YourSecurePassword123!;TrustServerCertificate=true;
DB_PASSWORD=YourSecurePassword123!

# JWT Configuration
JWT_KEY=SuaChaveSecretaSuperSegura123456789ComPeloMenos256Bits
JWT_ISSUER=CoopSystem
JWT_AUDIENCE=CoopSystem.Users

# Redis Configuration
REDIS_CONNECTION=redis:6379

# Frontend Configuration
FRONTEND_API_URL=https://your-domain.com
ENVIRONMENT=production

# SSL Configuration (para HTTPS)
SSL_CERT_PATH=/etc/nginx/ssl/certificate.crt
SSL_KEY_PATH=/etc/nginx/ssl/private.key

# Monitoring (opcional)
GRAFANA_PASSWORD=YourGrafanaPassword123!

# Application Settings
COOPSYSTEM_SETTINGS__SYSTEMNAME=CoopSystem
COOPSYSTEM_SETTINGS__VERSION=2.0.0
COOPSYSTEM_SETTINGS__ENABLEMODULES=Recoopera

# Logging
LOGGING__LOGLEVEL__DEFAULT=Information
LOGGING__LOGLEVEL__MICROSOFT=Warning
LOGGING__LOGLEVEL__MICROSOFT__ENTITYFRAMECORE=Warning

# CORS
CORS__ALLOWEDORIGINS=https://your-domain.com,https://www.your-domain.com
CORS__ALLOWEDMETHODS=GET,POST,PUT,DELETE,OPTIONS
CORS__ALLOWEDHEADERS=Content-Type,Authorization

# Rate Limiting
RATELIMITING__PERMITLIMIT=100
RATELIMITING__WINDOWSECONDS=60

# Cache Configuration
CACHE__DEFAULTSLIDINGEXPIRATION=300
CACHE__DEFAULTABSOLUTEEEXPIRATION=3600
